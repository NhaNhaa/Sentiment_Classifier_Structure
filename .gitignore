# =============================================================================
# SENSITIVE DATA & ENVIRONMENT FILES
# =============================================================================

# Environment variables and secrets (NEVER commit these)
.env
.env.*                   # any variant
!.env.example             # allow example template
*.pem
*.key
secrets.json
credentials.json
token.json
.aws/
gcp-credentials.json
# Add API keys for Hugging Face or other AI providers if saved locally
*.api_key

# =============================================================================
# LARGE MODEL ARTIFACTS & DATA (Hundreds of MB to GB)
# =============================================================================

# Saved model files and checkpoints
models/
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.bin
*.safetensors
*.ckpt
*.onnx
*.tflite

# Hugging Face cache and downloads
data/cache/
data/processed/
~/.cache/huggingface/
~/.cache/torch/
transformers_cache/
pretrained_models/

# Datasets
*.csv.gz
*.tar.gz
*.zip
*.7z
data/*.csv                # optional: ignore any raw data files

# =============================================================================
# VIRTUAL ENVIRONMENT (Already created, don't commit)
# =============================================================================

venv/
venv
env/
ENV/
.venv/
.virtualenv/
pip-log.txt
pip-delete-this-directory.txt

